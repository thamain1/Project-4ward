# Copy to .env.local and fill in. .env.local is gitignored — never commit real values.

# Client-safe (exposed to the browser bundle via Vite's VITE_ prefix):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server / tooling only — NEVER expose to the client, NEVER commit:
SUPABASE_PROJECT_REF=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
# Supabase Management API token (for applying migrations via the Management API).
# Prefer Windows Credential Manager over a file when possible.
SUPABASE_ACCESS_TOKEN=

# Gemini (Helios) — embeddings/extraction. Used ONLY by the ingest embed phase
# (never in the same process as the service-role key).
GEMINI_API_KEY=
# Optional: override the local memory corpus dir for ingestion (defaults to the ~/.claude memory path).
MEMORY_DIR=

# ── SPLIT ENV FILES FOR INGESTION (least privilege — Aegis 0002 r3 #1) ──
# Do NOT use the combined .env.local for ingestion. Use two single-purpose, gitignored files:
#   .env.embed.local    -> GEMINI_API_KEY (+ optional MEMORY_DIR) ONLY
#       node --env-file=.env.embed.local   scripts/ingest-embed.mjs
#   .env.persist.local  -> VITE_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY ONLY
#       node --env-file=.env.persist.local scripts/ingest-persist.mjs
# Each script refuses to start if the forbidden counterpart key is present in its environment.
